# ---------------------------------------------------------------
# Autocell Backend - Variáveis de ambiente
# Copia este ficheiro para ".env" e preenche com os teus valores.
# NUNCA faças commit do ficheiro ".env" real.
# ---------------------------------------------------------------

# URI de ligação ao MongoDB (MongoDB Atlas, Render, etc.)
MONGODB_URI=mongodb://localhost:27017/autocell

# Porta onde a API vai ouvir (no Render costuma ser injetada automaticamente)
PORT=5000

# Segredo usado para assinar/verificar os JWT (USE UM VALOR ALEATÓRIO LONGO EM PRODUÇÃO).
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=autocell-dev-secret-change-me

# Tempo de expiração dos JWT (formato jsonwebtoken: ex. "7d", "12h", "3600s").
JWT_EXPIRACAO=7d

# URL do frontend (para CORS — apenas esta origem é aceita).
# Em produção: https://autocell.vercel.app (ou o teu domínio Vercel)
FRONTEND_URL=http://localhost:3000

# API Key do Smoobu para sincronização em massa de reservas (REST API).
# Obtém-a no painel do Smoobu: Settings > API > API Key.
# Usada por POST /api/admin/smoobu/sincronizar (controllers/smoobuController.js).
# Sem esta variável, a sincronização devolve 400 (não configurada).
SMOOBU_API_KEY=

# --- Notificações Push (Web Push API / VAPID) ---
# Gera as chaves com: npx web-push generate-vapid-keys
# (corre na pasta backend/ após npm install)
#
# VAPID_PUBLIC_KEY  — chave pública (partilhada com o browser para subscrição)
# VAPID_PRIVATE_KEY — chave privada (guarda sigilosamente; assina as notificações)
# VAPID_SUBJECT     — identificador do emissor (email ou URL):
#                     ex: mailto:admin@autocell.com
#
# Sem estas variáveis, o endpoint /api/auth/me/push-subscribe devolve 503
# (serviço não configurado) e as notificações push são ignoradas silenciosamente.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@autocell.com
