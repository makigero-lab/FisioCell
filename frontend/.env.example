# ---------------------------------------------------------------
# Autocell Frontend - Variáveis de ambiente
# Copia este ficheiro para ".env.local" e preenche se necessário.
# Nesta fase (mock data) não é obrigatório preencher.
# ---------------------------------------------------------------

# URL base da API backend (Render). Usada quando o frontend começar a
# ligar-se à API (por enquanto usamos dados fictícios).
NEXT_PUBLIC_API_URL=https://autocell-backend.onrender.com

# Chave pública VAPID para notificações push (Web Push API).
# Tem de ser a MESMA chave que está no backend (VAPID_PUBLIC_KEY).
# Gera com: npx web-push generate-vapid-keys (na pasta backend/)
# Sem esta variável, o banner de ativar notificações não aparece.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
